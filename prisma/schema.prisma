// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth Models ---
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  OPERATOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          UserRole  @default(OPERATOR)

  accounts     Account[]
  sessions     Session[]
  transactions Transaction[] // Operator who processed the scan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- Domain Models ---

enum HTCondition {
  GOOD
  BROKEN
}

enum HTStatus {
  AVAILABLE
  BORROWED
}

model HT_Item {
  id         String      @id @default(cuid())
  ht_code    String      @unique // e.g., "HT-001"
  brand_type String // e.g., "Baofeng UV-5R"
  condition  HTCondition @default(GOOD)
  status     HTStatus    @default(AVAILABLE)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ht_items")
}

model Borrower {
  id            String @id @default(cuid())
  borrower_code String @unique // e.g., "P-001"
  full_name     String
  department    String // e.g., "Keamanan"

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("borrowers")
}

enum TransactionStatus {
  BORROWED
  RETURNED
}

model Transaction {
  id String @id @default(cuid())

  ht_id   String
  ht_item HT_Item @relation(fields: [ht_id], references: [id])

  borrower_id String
  borrower    Borrower @relation(fields: [borrower_id], references: [id])

  borrow_time DateTime  @default(now())
  return_time DateTime?

  status TransactionStatus @default(BORROWED)

  operator_id String
  operator    User   @relation(fields: [operator_id], references: [id])

  createdAt DateTime @default(now())

  @@map("transactions")
}
